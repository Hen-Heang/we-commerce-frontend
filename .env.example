# Template for environment variables.
# Copy this file to `.env.local` and fill in the values you need.
# `.env.local` is gitignored and only affects your machine.
#
# For Vercel production: set these in Vercel Dashboard → Settings → Environment Variables.

# Base URL for the Spring Boot backend, including the /api/v1 prefix.
#
# Local dev (run Spring Boot on localhost:8080):
#   NEXT_PUBLIC_API_URL=http://localhost:8080/api/v1
#
# Test against production backend without running it locally:
#   NEXT_PUBLIC_API_URL=https://we-commerce-api.onrender.com/api/v1
#
# In Vercel, set this to the Render URL above for the production deployment.
NEXT_PUBLIC_API_URL=http://localhost:8080/api/v1

# Optional. Set to "true" to disable mock-data fallback in lib/products.ts etc.
# By default the app shows seeded mock data when the API returns empty.
# NEXT_PUBLIC_DISABLE_MOCK=false
